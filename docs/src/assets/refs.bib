@article{manners_fast_2024,
    author = {Manners, James},
    title = {A fast and flexible scheme for photolysis and radiative heating of the whole atmosphere},
    journal = {AIP Conference Proceedings},
    volume = {2988},
    number = {1},
    pages = {030002},
    year = {2024},
    month = {01},
    abstract = {A flexible new scheme has been implemented in the Socrates radiative transfer code in order to parametrise a unified treatment of radiative heating, photolysis and photoionisation covering the whole spectrum of solar emission. This introduces two novel techniques. The first is a replacement of the plane-parallel approximation with the pseudo-spherical approximation, allowing the calculation of solar radiation absorbed in the twilight regions of the atmosphere where the solar zenith angle is greater than 90. The second is an accurate spectral calculation of photolysis rates using a new technique to map the fluxes calculated using the correlated-k method onto a high resolution spectrum. Configurations have been developed to cover far and extreme-UV wavelengths suitable for General Circulation Models (GCMs) extending into the lower thermosphere.},
    issn = {0094-243X},
    doi = {10.1063/5.0185476},
    url = {https://doi.org/10.1063/5.0185476},
    eprint = {https://pubs.aip.org/aip/acp/article-pdf/doi/10.1063/5.0185476/18570153/030002\_1\_5.0185476.pdf},
}

