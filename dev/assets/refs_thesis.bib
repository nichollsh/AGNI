abstract = {New multianvil experimental data are reported for the anhydrous solidus for peridotite KLB-1 at 5 to 9.7 GPa. The solidus is unaffected by variable experimental run durations, but it is lowered in temperature when rhenium capsules are replaced with graphite. Using data reported previously, the anhydrous solidus for KLB-1 can be described by T = 1086  5.7P + 390 ln P (68C 2) at pressures that range from 2.7 to 22.5 GPa. At lower pressures the effect of composition on the temperature of the spinel peridotite solidus is small and dominated by alkali abundances; variations in Mg number have almost no effect on solidus temperature.},
year = {2000}
}



