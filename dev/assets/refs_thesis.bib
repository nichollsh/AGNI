@article{hu_narrow_2023,
	title = {Narrow loophole for {H2}-dominated atmospheres on habitable rocky planets around {M} dwarfs},
	copyright = {arXiv.org perpetual, non-exclusive license},
	url = {https://arxiv.org/abs/2304.13659},
	doi = {10.48550/ARXIV.2304.13659},
	abstract = {Habitable rocky planets around M dwarfs that have H2-dominated atmospheres, if they exist, would permit characterizing habitable exoplanets with detailed spectroscopy using JWST, owing to their extended atmospheres and small stars. However, the H2-dominated atmospheres that are consistent with habitable conditions cannot be too massive, and a moderate-size H2-dominated atmosphere will lose mass to irradiation-driven atmospheric escape on rocky planets around M dwarfs. We evaluate volcanic outgassing and serpentinization as two potential ways to supply H2 and form a steady-state H2-dominated atmosphere. For rocky planets of 1-7 Earth mass and early, mid, and late M dwarfs, the expected volcanic outgassing rates from a reduced mantle fall short of the escape rates by \&gt;{\textasciitilde}1 order of magnitude, and a generous upper limit of the serpentinization rate is still less than the escape rate by a factor of a few. Special mechanisms that may sustain the steady-state H2-dominated atmosphere include direct interaction between liquid water and mantle, heat-pipe volcanism from a reduced mantle, and hydrodynamic escape slowed down by efficient upper-atmospheric cooling. It is thus unlikely to find moderate-size, H2-dominated atmospheres on rocky planets of M dwarfs that would support habitable environments.},
	urldate = {2023-04-28},
	author = {Hu, Renyu and Gaillard, Fabrice and Kite, Edwin},
	year = {2023},
	note = {Publisher: arXiv
Version Number: 1},
	keywords = {Earth and Planetary Astrophysics (astro-ph.EP), FOS: Physical sciences, Solar and Stellar Astrophysics (astro-ph.SR)},
	file = {Hu et al. - 2023 - Narrow loophole for H2-dominated atmospheres on ha.pdf:/Users/nichollsh/Zotero/storage/7CUHE6CZ/Hu et al. - 2023 - Narrow loophole for H2-dominated atmospheres on ha.pdf:application/pdf},
}

